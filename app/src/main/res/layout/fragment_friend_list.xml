<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/bg_friendships">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_header"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="20dp"
        android:paddingBottom="14dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.15">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Amigos"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_count" />

        <TextView
            android:id="@+id/tv_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"

            tools:text="5 amigos"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Buscador filtro -->
    <LinearLayout
        android:id="@+id/search_bar_filter"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="@drawable/shape_pill_button"
        app:layout_constraintTop_toBottomOf="@id/layout_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            android:contentDescription="Search icon"
            app:tint="@color/bg_banner" />

        <EditText
            android:id="@+id/et_filter"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@null"
            android:hint="Buscar amigo..."
            android:textColor="@color/white"
            android:textColorHint="#80FFFFFF"
            android:textSize="14sp"
            android:inputType="text"
            android:textStyle="bold"
            android:imeOptions="actionSearch"
            android:singleLine="true" />

    </LinearLayout>

    <View
        android:id="@+id/separator_1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2B2D31"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/search_bar_filter"/>

    <!-- Lista -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_friends"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/separator_1"
        app:layout_constraintBottom_toTopOf="@id/separator_2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        tools:listitem="@layout/item_friend"/>

    <View
        android:id="@+id/separator_2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2B2D31"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/search_bar_add"/>

    <!-- Sección añadir amigo -->
    <LinearLayout
        android:id="@+id/search_bar_add"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:background="@drawable/shape_pill_button"
        app:layout_constraintBottom_toTopOf="@id/separator_3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_friend_search"
            android:contentDescription="Search icon"
            app:tint="@color/bg_banner" />

        <EditText
            android:id="@+id/et_add_friend"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@null"
            android:hint="Buscar usuario..."
            android:textColor="@color/white"
            android:textColorHint="#80FFFFFF"
            android:textSize="14sp"
            android:inputType="text"
            android:textStyle="bold"
            android:imeOptions="actionSearch"
            android:singleLine="true" />

        <ImageButton
            android:id="@+id/btn_clear_search"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/shape_circle"
            android:padding="2dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_decline"
            app:tint="@color/text_primary" />

        <Button
            android:id="@+id/btn_search_users"
            style="@style/PrimaryButton"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Buscar"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:id="@+id/separator_3"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2B2D31"
        android:layout_marginTop="20dp"
        app:layout_constraintBottom_toTopOf="@id/rv_search_results"/>

    <androidx.recyclerview.widget.RecyclerView
        android:background="@color/bg_friendships_2"
        android:id="@+id/rv_search_results"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        app:layout_constraintHeight_max="250dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        tools:listitem="@layout/item_friend_add"/>

</androidx.constraintlayout.widget.ConstraintLayout>