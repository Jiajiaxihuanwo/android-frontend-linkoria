<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 1. EL FONDO PRIMERO (Para que esté detrás) -->
    <View
        android:id="@+id/sidebar_background"
        android:layout_width="70dp"
        android:layout_height="0dp"
        android:background="@color/bg_sidebar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 2. BOTÓN ADD (Centrado en la sidebar) -->
    <ImageButton
        android:id="@+id/btn_add_server"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/shape_rounded_button"
        android:src="@drawable/ic_add"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="@id/sidebar_background"
        app:layout_constraintStart_toStartOf="@id/sidebar_background"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 3. RECYCLER (Ancho 0dp para que respete los márgenes dentro de la sidebar) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_servers"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/btn_dms"
        app:layout_constraintEnd_toEndOf="@id/sidebar_background"
        app:layout_constraintStart_toStartOf="@id/sidebar_background"
        app:layout_constraintTop_toBottomOf="@id/btn_add_server" />

    <!-- 4. BOTÓN DMS (Abajo, centrado en la sidebar) -->
    <ImageButton
        android:id="@+id/btn_dms"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/shape_rounded_button"
        android:src="@drawable/ic_dm"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/sidebar_background"
        app:layout_constraintStart_toStartOf="@id/sidebar_background" />

    <!-- 5. NAVHOST (Ocupa el resto de la pantalla) -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment_dashboard"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph_conversations"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar_background"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>