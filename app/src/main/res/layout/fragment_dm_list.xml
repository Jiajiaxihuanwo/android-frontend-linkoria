<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#2C2F33">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#23272A"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Texto arriba -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Messages"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <!-- Iconos abajo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_search"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_search"
                android:scaleType="centerInside"
                android:background="@drawable/shape_rounded_button_sm"
                android:contentDescription="Search" />

            <ImageButton
                android:id="@+id/btn_add_friend"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_friend_add"
                android:scaleType="centerInside"
                android:background="@drawable/shape_rounded_button_sm"
                android:contentDescription="Add friend" />

        </LinearLayout>

    </LinearLayout>

    <!-- DM List RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/dm_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingVertical="8dp" />

</LinearLayout>