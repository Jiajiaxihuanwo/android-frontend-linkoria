<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>

        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#EDEDED</item>

        <item name="cornerRadius">20dp</item>
        <item name="backgroundTint">#243B7A</item>

        <item name="rippleColor">#22000000</item>

        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">2dp</item>
    </style>


    <style name="GlassButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>

        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#E6E6E6</item>

        <item name="cornerRadius">20dp</item>

        <item name="backgroundTint">#22FFFFFF</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#88FFFFFF</item>

        <item name="rippleColor">#33FFFFFF</item>

        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">0dp</item>
    </style>

</resources>
