<?xml version="1.0" encoding="utf-8"?>
<resources>

<!--    BUTTONS-->
    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>

        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#EDEDED</item>

        <item name="cornerRadius">20dp</item>
        <item name="backgroundTint">@color/primary_button_background_tint</item>

        <item name="rippleColor">#22000000</item>

        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">2dp</item>
    </style>


    <style name="GlassButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>

        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#E6E6E6</item>

        <item name="cornerRadius">20dp</item>

        <item name="backgroundTint">#22FFFFFF</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#88FFFFFF</item>

        <item name="rippleColor">#33FFFFFF</item>

        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">0dp</item>
    </style>

<!--    INPUT TEXT LAYOUT-->
    <style name="CustomTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <!-- Background y Stroke -->
        <item name="boxBackgroundColor">@color/dark_gray</item>
        <item name="boxStrokeColor">@color/primary_blue</item>
        <item name="boxStrokeWidthFocused">2dp</item>

        <item name="boxCornerRadiusBottomEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
        <item name="boxCornerRadiusTopStart">20dp</item>

        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!--Cardview-->
    <style name="TopLeftRoundedCard" parent="">
        <item name="cornerSizeTopLeft">32dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="TransparentBottomSheet" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/TransparentBottomSheetStyle</item>
    </style>

    <style name="TransparentBottomSheetStyle" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="background">@android:color/transparent</item>
    </style>

</resources>
