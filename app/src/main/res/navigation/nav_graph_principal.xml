<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph_principal"
    app:startDestination="@id/authContainerFragment">

    <fragment
        android:id="@+id/authContainerFragment"
        android:name="com.xinlei.frontend.linkoria.app.auth.ui.AuthContainerFragment"
        android:label="AuthContainerFragment"
        tools:layout="@layout/fragment_auth_container">
        <action
            android:id="@+id/action_authContainerFragment_to_mainContainerFragment"
            app:destination="@id/mainContainerFragment"
            app:popUpTo="@id/authContainerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/mainContainerFragment"
        android:name="com.xinlei.frontend.linkoria.app.root.MainContainerFragment"
        android:label="MainContainerFragment"
        tools:layout="@layout/fragment_main_container" />

</navigation>