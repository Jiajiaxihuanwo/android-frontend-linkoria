<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40FFFFFF"> <!-- Ripple blanco semitransparente -->

    <item>
        <selector>
            <!-- Estado Deshabilitado -->
            <item android:state_enabled="false">
                <shape android:shape="oval">
                    <solid android:color="@color/btn_disabled" />
                    <size android:width="56dp" android:height="56dp" />
                </shape>
            </item>

            <!-- Estado Por Defecto (Habilitado) -->
            <item>
                <shape android:shape="oval">
                    <solid android:color="@color/btn_primary" />
                    <size android:width="56dp" android:height="56dp" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>